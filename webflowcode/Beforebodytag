  function addSlideToTimeline(tl, el, inPos, slideIndex) {
    if (!el) return;
    const outPos = inPos + 0.20; // hold window before next slide starts

    // ── IN ──
    tl.set(el.slide, { visibility: 'visible' }, inPos)
      .to(el.slide, { opacity: 1, duration: 0.03, ease: 'power2.out' }, inPos)
      .to(el.centerBox, { scale: 1, opacity: 1, duration: 0.06, ease: 'power2.out' }, inPos)
      .to(el.sidebars, { scale: 1, opacity: 1, duration: 0.06, stagger: 0.015, ease: 'power2.out' }, inPos + 0.03)
      .to(el.boxes, { y: 0, opacity: 1, duration: 0.06, stagger: 0.01, ease: 'power2.out' }, inPos + 0.06)
      .to(el.headings, { opacity: 1, x: 0, duration: 0.06, stagger: 0.015, ease: 'power2.out' }, inPos + 0.09)
