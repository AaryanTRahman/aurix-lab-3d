<!-- GSAP, ScrollTrigger, Swiper, and Lenis -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
<script>
(function() {
  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'auto';
  }
  window.addEventListener('pageshow', function() {
    if (typeof ScrollTrigger !== 'undefined') {
      ScrollTrigger.refresh();
    }
  });
})();

const isTouchDevice = ('ontouchstart' in window) || navigator.maxTouchPoints > 0;
const isMobileDevice = window.innerWidth <= 767 || isTouchDevice;

// FIX: Only initialize Lenis on actual desktop devices. 
// This completely stops the "swinging back" momentum conflict.
let lenis = null;
if (!isMobileDevice) {
  lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    orientation: 'vertical',
    smoothWheel: true,
    infinite: false,
  });
}
  // Add this immediately after your Lenis initialization block
if (lenis) {
  window.addEventListener("resize", () => {
    // Only resize Lenis when the window is actually done resizing, 
    // to prevent the jumpy layout issues.
    clearTimeout(window.lenisResizeTimer);
    window.lenisResizeTimer = setTimeout(() => {
      lenis.resize();
    }, 500);
  });
}

document.addEventListener('DOMContentLoaded', function() {
  gsap.registerPlugin(ScrollTrigger);
	// THIS IS THE KEY: Normalize Scroll
    // This handles the conflict between smooth-scrolling (Lenis) 
    // and GSAP pinning/triggering natively.
    ScrollTrigger.normalizeScroll(true);
    
    // Also, explicitly link Lenis and ScrollTrigger properly
    if (lenis) {
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });
      // Use lagSmoothing to prevent jumps when the browser frame-drops
      gsap.ticker.lagSmoothing(0); 
    }
  // FIX: ResizeObserver to catch Webflow lazy-loaded images and late Spline injections
    // This permanently prevents the "sometimes jumping" by keeping GSAP's math 100% accurate.
    // let resizeTimer;
    // const bodyObserver = new ResizeObserver(() => {
    //   clearTimeout(resizeTimer);
    //   resizeTimer = setTimeout(() => {
    //     ScrollTrigger.refresh();
    //   }, 200); 
    // });
    // bodyObserver.observe(document.body);

  // Ignore address bar resizes so pins don't break
  ScrollTrigger.config({ ignoreMobileResize: true,
      // FIX 3: Limits how often GSAP is allowed to recalculate layout shifts. 
      // This saves massive CPU power during the heavy initial page load.
      limitCallbacks: true });

  if (lenis) {
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);
  }
  // Wait for all images/fonts to finish loading, then refresh coordinates
  window.addEventListener('load', function() {
    ScrollTrigger.refresh();
  });
(function() {
  document.body.style.overflow = 'hidden';
  document.documentElement.style.overflow = 'hidden';
  // if (typeof lenis !== 'undefined') {
  //   lenis.stop();
  // }
  if (lenis) {
    lenis.stop();
  }

  let hasCompletedPreloaderTransition = false;

  const preloaderWrapper = document.querySelector('.preloader-wrapper');
  const preloaderVideoDesktop = document.querySelector('.preloader-wrapper video, .preloader-player');
  if (preloaderVideoDesktop) {
    preloaderVideoDesktop.muted = true;
    preloaderVideoDesktop.setAttribute('muted', '');
    preloaderVideoDesktop.setAttribute('playsinline', '');
    preloaderVideoDesktop.setAttribute('preload', 'auto');
    preloaderVideoDesktop.playsInline = true;
    preloaderVideoDesktop.loop = false;
    preloaderVideoDesktop.pause();
  }

  const heroIconBtn = document.querySelector('.hero-content-wrapper .icon-btn-wrapper');
  const navbar = document.querySelector('.navbar-wrapper');

  const preloaderState = window.__aurixPreloaderState = window.__aurixPreloaderState || {
    pageReady: false,
    sceneReady: false,
    videoStarted: false
  };

  if (heroIconBtn) {
    heroIconBtn.style.opacity = '0';
    heroIconBtn.style.visibility = 'hidden';
    heroIconBtn.style.transition = 'opacity 0.8s ease-out, visibility 0.8s';
  }
  if (navbar) {
    navbar.style.opacity = '0';
    navbar.style.visibility = 'hidden';
    navbar.style.transition = 'opacity 0.8s ease-out, visibility 0.8s';
  }

  function enableScrolling() {
    document.body.style.overflow = '';
    document.documentElement.style.overflow = '';
    // if (typeof lenis !== 'undefined') {
    if (lenis) {
      lenis.start();
    }
    if (typeof ScrollTrigger !== 'undefined') {
      ScrollTrigger.refresh();
    }
  }

  function transitionToHero() {
    // console.log('transitionToHero called, hasCompleted:', hasCompletedPreloaderTransition);
    if (hasCompletedPreloaderTransition) return;
    hasCompletedPreloaderTransition = true;

    if (!preloaderWrapper) {
      console.log('Starting sequential init');
      startSequentialSectionInit();
      enableScrolling();
      return;
    }

    preloaderWrapper.style.transition = 'opacity 0.5s ease-out';
    preloaderWrapper.style.opacity = '0';

    setTimeout(() => {
      preloaderWrapper.style.display = 'none';
      setTimeout(() => {
        if (heroIconBtn) {
          heroIconBtn.style.visibility = 'visible';
          heroIconBtn.style.opacity = '1';
        }
        if (navbar) {
          navbar.style.visibility = 'visible';
          navbar.style.opacity = '1';
        }
        startSequentialSectionInit();
        setTimeout(() => {
          enableScrolling();
        }, 300);
      }, 100);
    }, 500);
  }

  function finalizePreloaderVideoState() {
    transitionToHero();
  }

  function tryStartPreloaderVideo() {
    if (!preloaderVideoDesktop || preloaderState.videoStarted) return;
    if (!preloaderState.pageReady || !preloaderState.sceneReady) return;

    preloaderState.videoStarted = true;
    try {
      preloaderVideoDesktop.currentTime = 0;
    } catch (error) {
      console.warn('Could not reset preloader video time', error);
    }

    const playPromise = preloaderVideoDesktop.play();
    if (playPromise && typeof playPromise.catch === 'function') {
      playPromise.catch(function() {
        finalizePreloaderVideoState();
      });
    }
  }

  function markPreloaderPageReady() {
    if (preloaderState.pageReady) return;
    preloaderState.pageReady = true;
    tryStartPreloaderVideo();
  }

  function markPreloaderSceneReady() {
    if (preloaderState.sceneReady) return;
    preloaderState.sceneReady = true;
    tryStartPreloaderVideo();
  }

  window.addEventListener('aurix:scene-ready', markPreloaderSceneReady, { once: true });

  Promise.all([
    document.fonts ? document.fonts.ready.catch(() => undefined) : Promise.resolve(),
    new Promise((resolve) => {
      if (document.readyState === 'complete') {
        resolve();
      } else {
        window.addEventListener('load', resolve, { once: true });
      }
    })
  ]).then(markPreloaderPageReady);

  if (preloaderVideoDesktop) {
    const freezeOnFirstFrame = function() {
      try {
        preloaderVideoDesktop.currentTime = 0;
      } catch (error) {
        console.warn('Could not freeze preloader first frame', error);
      }
      preloaderVideoDesktop.pause();
    };

    if (preloaderVideoDesktop.readyState >= 2) {
      freezeOnFirstFrame();
    } else {
      preloaderVideoDesktop.addEventListener('loadeddata', freezeOnFirstFrame, { once: true });
    }

    preloaderVideoDesktop.addEventListener('ended', finalizePreloaderVideoState, { once: true });
    preloaderVideoDesktop.addEventListener('error', finalizePreloaderVideoState, { once: true });
  }

  // Shared failsafe so the loader never deadlocks if Webflow or the 3D scene stalls.
  setTimeout(() => {
    if (hasCompletedPreloaderTransition) return;
    if (preloaderVideoDesktop && !preloaderState.videoStarted) {
      preloaderState.pageReady = true;
      preloaderState.sceneReady = true;
      tryStartPreloaderVideo();
      setTimeout(() => {
        if (!hasCompletedPreloaderTransition) {
          finalizePreloaderVideoState();
        }
      }, 9000);
      return;
    }
    finalizePreloaderVideoState();
  }, 20000);
})();
