  // }
// FIX 1: Use a state tracker to stop spamming the browser's media engine.
  // This prevents the 3D scene from crashing while allowing instant autoplay.
  let currentlyPlayingIndex = -1;
  let isCurrentlyPlayingState = false;

  function setParticleVideoState(activeIndex = 0, shouldPlay = false) {
    // If the slide hasn't changed and the play state is the same, DO NOTHING.
    if (currentlyPlayingIndex === activeIndex && isCurrentlyPlayingState === shouldPlay) return;

    particleSlides.forEach((slide, index) => {
      slide.querySelectorAll('video').forEach((video) => {
        
        // Ensure iOS strict attributes are set
        video.muted = true;
        video.playsInline = true;
        video.setAttribute('playsinline', '');

        if (!shouldPlay || index !== activeIndex) { 
          if (!video.paused) video.pause(); 
        } else {
          // if (video.paused) {
          //   // We use a promise-safe play to prevent the autoplay error
          //   const playPromise = video.play();
          //   if (playPromise !== undefined) {
          //     playPromise.catch(error => {
          //       // If blocked, we mute and try again (Browser-standard fallback)
          //       video.muted = true;
          //       video.play();
          //     });
          //   }
          // }
          if (video.paused) {
            video.play();
          }
        }
      });
    });

    // Update the tracker
    currentlyPlayingIndex = activeIndex;
    isCurrentlyPlayingState = shouldPlay;
  }
  function syncParticleVideoPlayback(activeIndex = currentSlideIndex) {
    setParticleVideoState(activeIndex, particleSectionActive && sliderFullyVisible);
  }
  prepareParticleVideos();

  // ── Progress bar ──────────────────────────────────────────────────────────
  function updateProgressBar(index) {
    const progress = ((index + 1) / totalSlides) * 100;
    gsap.to('#progressBar', { width: progress + '%', duration: 0.3, ease: 'power2.out' });
  }

  // ── Get slide child elements ──────────────────────────────────────────────
  function getSlideElements(slideIndex) {
    const slide = particleSlides[slideIndex];
    if (!slide) return null;
    const scene = slide.querySelector('.grid-wrapper');
    return {
      slide,
      centerBox: scene?.querySelector('.center-box'),
      sidebars: scene?.querySelectorAll('.sidebar-left, .sidebar-right'),
      boxes: scene?.querySelectorAll('.top-box, .bottom-box'),
      headings: slide.querySelectorAll('.spline-slide-heading, .spline-slide-heading.right'),
      desc: slide.querySelector('.slide-des'),
      btn: slide.querySelector('.spline-slide-btn-wrapper')
    };
  }

  // ── Initial CSS state ─────────────────────────────────────────────────────
  // slides-container needs to be a positioned container
  const slidesContainer = slider.querySelector('.slides-container');
  if (slidesContainer) {
    gsap.set(slidesContainer, {
      position: 'relative',
      width: '100%',
      height: '100%'
    });
