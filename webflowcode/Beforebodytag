    }, 0.12)
    .set(starBgBox, { visibility: 'hidden' }, 0.27)
    .set(slider, {
      opacity: 1, visibility: 'visible',
      onStart: () => { sliderFullyVisible = true; syncParticleVideoPlayback(0); },
      onReverseComplete: () => { sliderFullyVisible = false; setParticleVideoState(0, false); }
    }, 0.12);

  // ── Navbar + scroll indicator (identical to original) ─────────────────────
  mainTl
    .to(navbarLogo, { opacity: 1, visibility: 'visible', duration: 0.10, ease: 'power2.inOut' }, 0.20)
    .to(scrollIndicator, { opacity: 1, y: 0, visibility: 'visible', duration: 0.06, ease: 'power2.out' }, 0.30);

  // ── Slides (each spaced 0.24 apart matching your original 0.42/0.66/0.90) ──
  addSlideToTimeline(mainTl, slide1, 0.18, 0);
  addSlideToTimeline(mainTl, slide2, 0.42, 1);
