  let sliderFullyVisible = false;
  let fallingStarsInstance = null;
  let particleSectionActive = false;
  const particleIsMobile = window.innerWidth < 768;
  const particleIsTablet = window.innerWidth >= 768 && window.innerWidth < 1024;
  const reduceParticleMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const particleStarConfig = {
    count: reduceParticleMotion ? 0 : (particleIsMobile ? 36 : particleIsTablet ? 54 : 72),
    shadowBlur: reduceParticleMotion ? 0 : (particleIsMobile ? 0 : particleIsTablet ? 8 : 12)
  };
  const particleSlides = Array.from(section.querySelectorAll('.spline-slider-wrapper .slide-item'));

  // ── Star background (unchanged) ──────────────────────────────────────────
  function initializeStarBackground() {
    const canvas = document.getElementById('starsCanvas');
    const container = document.getElementById('starsContainer');
    if (!canvas || !container) return;
    class FallingStars {
      constructor(canvas, options = {}) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.color = options.color || '#FFF';
        this.count = options.count || 72;
        this.shadowBlur = options.shadowBlur ?? 12;
        this.stars = [];
        this.perspective = 0;
        this.animationFrame = null;
        this.isAnimating = false;
        this.init();
      }
      init() {
        this.resizeCanvas();
        
        // FIX: Debounce the resize event so it doesn't lag mobile scrolling
        let resizeTimeout;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(() => {
            this.resizeCanvas();
          }, 250); // Waits for scrolling/resizing to stop before recalculating
        });
        
        if (this.canvas.width > 0 && this.canvas.height > 0) this.initStars();
      }
      initStars() {
        this.perspective = this.canvas.width / 2;
        this.stars = [];
        for (let i = 0; i < this.count; i++) {
          this.stars.push({
            x: (Math.random() - 0.5) * 2 * this.canvas.width,
            y: (Math.random() - 0.5) * 2 * this.canvas.height,
            z: Math.random() * this.canvas.width,
            speed: Math.random() * 5 + 2
          });
        }
      }
      resizeCanvas() {
        const container = this.canvas.parentElement;
        const width = container.clientWidth;
        const height = container.clientHeight;
        if (width > 0 && height > 0) {
          this.canvas.width = width;
          this.canvas.height = height;
          this.canvas.style.width = width + 'px';
          this.canvas.style.height = height + 'px';
          this.perspective = this.canvas.width / 2;
          if (this.stars.length === 0) this.initStars();
        }
      }
      hexToRgb(hex) {
        hex = hex.replace(/^#/, '');
        if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
        const bigint = parseInt(hex, 16);
        return { r: (bigint >> 16) & 255, g: (bigint >> 8) & 255, b: bigint & 255 };
      }
      drawStar(star) {
        const scale = this.perspective / (this.perspective + star.z);
        const x2d = this.canvas.width / 2 + star.x * scale;
        const y2d = this.canvas.height / 2 + star.y * scale;
        const size = Math.max(scale * 3, 0.5);
        const prevScale = this.perspective / (this.perspective + star.z + star.speed * 15);
        const xPrev = this.canvas.width / 2 + star.x * prevScale;
        const yPrev = this.canvas.height / 2 + star.y * prevScale;
        const rgb = this.hexToRgb(this.color);
        if (this.shadowBlur > 0) {
          this.ctx.save();
          this.ctx.strokeStyle = `rgba(${rgb.r},${rgb.g},${rgb.b},0.18)`;
          this.ctx.lineWidth = size * 1.9;
          this.ctx.shadowBlur = this.shadowBlur;
          this.ctx.shadowColor = `rgba(${rgb.r},${rgb.g},${rgb.b},0.65)`;
          this.ctx.beginPath();
          this.ctx.moveTo(x2d, y2d);
          this.ctx.lineTo(xPrev, yPrev);
          this.ctx.stroke();
          this.ctx.restore();
        }
        this.ctx.strokeStyle = `rgba(${rgb.r},${rgb.g},${rgb.b},0.6)`;
        this.ctx.lineWidth = size;
        this.ctx.beginPath();
        this.ctx.moveTo(x2d, y2d);
        this.ctx.lineTo(xPrev, yPrev);
        this.ctx.stroke();
        this.ctx.fillStyle = `rgba(${rgb.r},${rgb.g},${rgb.b},1)`;
        this.ctx.beginPath();
        this.ctx.arc(x2d, y2d, size / 4, 0, Math.PI * 2);
        this.ctx.fill();
      }
      animate() {
        if (!this.isAnimating) return;
        if (this.canvas.width === 0 || this.canvas.height === 0) return;
        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
        this.stars.forEach(star => {
          this.drawStar(star);
          star.z -= star.speed;
          if (star.z <= 0) {
            star.z = this.canvas.width;
            star.x = (Math.random() - 0.5) * 2 * this.canvas.width;
            star.y = (Math.random() - 0.5) * 2 * this.canvas.height;
          }
        });
        this.animationFrame = requestAnimationFrame(() => this.animate());
      }
      start() {
        if (!this.isAnimating) {
          if (this.count === 0) return;
          this.isAnimating = true;
          this.resizeCanvas();
          if (this.stars.length === 0) this.initStars();
          this.animate();
        }
      }
      stop() {
        this.isAnimating = false;
        if (this.animationFrame) {
          cancelAnimationFrame(this.animationFrame);
          this.animationFrame = null;
        }
      }
      setColor(color) { this.color = color; }
    }
    fallingStarsInstance = new FallingStars(canvas, {
      color: '#FFF',
      count: particleStarConfig.count,
      shadowBlur: particleStarConfig.shadowBlur
    });
  }
  initializeStarBackground();

  function prepareParticleVideos() {
    particleSlides.forEach((slide) => {
