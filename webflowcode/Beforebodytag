<!-- GSAP, ScrollTrigger, and Lenis. Swiper is lazy-loaded only when the slider exists. -->
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
<script>

(function() {
  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'auto';
  }
  window.addEventListener('pageshow', function() {
    if (typeof ScrollTrigger !== 'undefined') {
      ScrollTrigger.refresh();
    }
  });
})();

// Pause preloader video immediately — hold first frame until loading overlay exits
(function() {
  var v = document.querySelector('.preloader-wrapper video');
  if (!v) return;
  v.__aurPaused = true;
  v.removeAttribute('loop');
  v.pause();
  v.currentTime = 0;
  v.addEventListener('play', function onPlay() {
    if (v.__aurPaused) { v.pause(); v.currentTime = 0; }
    else { v.removeEventListener('play', onPlay); }
  });
})();

const isTouchDevice = ('ontouchstart' in window) || navigator.maxTouchPoints > 0;
const isMobileDevice = window.innerWidth <= 767 || isTouchDevice;

let lenis = null;

document.addEventListener('DOMContentLoaded', function() {
  // Lazy-load all images not in the initial viewport
  document.querySelectorAll('img:not([fetchpriority="high"]):not([loading])').forEach(function(img) {
    if (!img.closest('.hero-section, .preloader-wrapper, .navbar-wrapper, .navbar31_component')) {
      img.loading = 'lazy';
    }
  });

  lenis = new Lenis(
    isMobileDevice
      ? {
          duration: 0.9,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          orientation: 'vertical',
          smoothWheel: true,
          smoothTouch: false,
          infinite: false,
        }
      : {
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          orientation: 'vertical',
          smoothWheel: true,
          infinite: false,
        }
  );
  if (lenis) {
    window.addEventListener("resize", () => {
      clearTimeout(window.lenisResizeTimer);
      window.lenisResizeTimer = setTimeout(() => {
        lenis.resize();
      }, 500);
    });
  }
  gsap.registerPlugin(ScrollTrigger);
  ScrollTrigger.normalizeScroll(!isMobileDevice);
  ScrollTrigger.config({ ignoreMobileResize: true, limitCallbacks: true });

  function syncHeroScrollIndicatorVisibility() {
    const heroScrollIndicatorWrapper = document.querySelector('.hero-section .scroll-indicator-wrapper');
    if (!heroScrollIndicatorWrapper) return;
    const currentY = window.scrollY || window.pageYOffset || 0;
    heroScrollIndicatorWrapper.classList.toggle('is-scrolled', currentY > 2);
  }

  function safeScrollTriggerRefresh(force = false) {
    if (typeof ScrollTrigger === 'undefined') return false;
    const currentY = window.scrollY || window.pageYOffset || 0;
    const safeZone = Math.max(window.innerHeight * 0.5, 240);
    if (!force && currentY > safeZone) {
      return false;
    }
    ScrollTrigger.refresh();
    return true;
  }

  if (lenis) {
    lenis.on('scroll', ScrollTrigger.update);
    lenis.on('scroll', syncHeroScrollIndicatorVisibility);
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);
  }
  syncHeroScrollIndicatorVisibility();
  window.addEventListener('scroll', syncHeroScrollIndicatorVisibility, { passive: true });
  window.addEventListener('resize', syncHeroScrollIndicatorVisibility);
  window.addEventListener('load', function() {
    syncHeroScrollIndicatorVisibility();
    safeScrollTriggerRefresh();
  });
(function () {
  const CFG = { holdSeconds: 0.3 };
  // Minimum ms: logo ends ~0.9s, dots appear ~1.9s — ensure animation plays before exit
  const MIN_DISPLAY_MS = 1500;

  const preloaderWrapper = document.querySelector('.preloader-wrapper');
  const heroIconBtn      = document.querySelector('.hero-content-wrapper .icon-btn-wrapper');
  const navbar           = document.querySelector('.navbar-wrapper');
  const heroScene        = document.querySelector('.hero-bg-3d-animation');
  const preloaderVideo   = preloaderWrapper ? preloaderWrapper.querySelector('video') : null;

  if (!preloaderWrapper) {
    revealHeroScene();
    startSequentialSectionInit();
    setTimeout(enableScrolling, 300);
    return;
  }

  let hasCompleted     = false;
  let hasStartedVideo  = false;
  let videoFinished    = false;
  let overlayDone      = false;
  let sceneIsReady     = false;
  let timelineIsReady  = false;
  let scrollLockActive = false;
  let scrollLockRaf    = null;
  let startVideoStage  = null;
  let videoFallbackId  = null;

  if (heroIconBtn) { heroIconBtn.style.cssText += 'opacity:0;visibility:hidden;transition:opacity 0.8s ease-out,visibility 0.8s;'; }
  if (navbar)      { navbar.style.cssText      += 'opacity:0;visibility:hidden;transition:opacity 0.8s ease-out,visibility 0.8s;'; }
  if (heroScene)   { heroScene.style.cssText   += 'opacity:0;visibility:hidden;'; }

  function clearVideoFallback() {
    if (!videoFallbackId) return;
    clearTimeout(videoFallbackId);
    videoFallbackId = null;
  }

  function revealHeroScene() {
    if (!heroScene) return;
    heroScene.style.visibility = 'visible';
    if (typeof gsap !== 'undefined') {
      gsap.killTweensOf(heroScene);
      gsap.to(heroScene, {
        opacity: 1,
        duration: 0.9,
        ease: 'power2.inOut',
        overwrite: 'auto'
      });
    } else {
      heroScene.style.opacity = '1';
    }
  }

  function scheduleVideoFallback() {
    if (!preloaderVideo) return;
    clearVideoFallback();
    const dur = preloaderVideo.duration;
    if (!(dur && isFinite(dur) && dur > 0)) return;
    videoFallbackId = setTimeout(() => {
      if (!hasCompleted && hasStartedVideo && !videoFinished) {
        completeTransition();
      }
    }, dur * 1000 + 1500);
  }

  function preventScroll(e) { e.preventDefault(); }
  function preventKeys(e) {
    if (['ArrowUp','ArrowDown','PageUp','PageDown','Home','End',' ','Spacebar'].includes(e.key)) e.preventDefault();
  }
  function keepAtTop() {
    if (!scrollLockActive) return;
    if (window.scrollY !== 0) window.scrollTo(0, 0);
    scrollLockRaf = requestAnimationFrame(keepAtTop);
  }
  function lockScrolling() {
    window.scrollTo(0, 0);
    scrollLockActive = true;
    const s = { overflow:'hidden', overscrollBehavior:'none', touchAction:'none',
                position:'fixed', top:'0', left:'0', right:'0', width:'100%', height:'100%' };
    Object.assign(document.documentElement.style, s);
    Object.assign(document.body.style, s);
    if (lenis) lenis.stop();
    window.addEventListener('wheel',     preventScroll, { passive:false, capture:true });
    window.addEventListener('touchmove', preventScroll, { passive:false, capture:true });
    window.addEventListener('keydown',   preventKeys,   true);
    keepAtTop();
  }
  function enableScrolling() {
    scrollLockActive = false;
    cancelAnimationFrame(scrollLockRaf);
    const s = { overflow:'', overscrollBehavior:'', touchAction:'',
                position:'', top:'', left:'', right:'', width:'', height:'' };
    Object.assign(document.documentElement.style, s);
    Object.assign(document.body.style, s);
    window.removeEventListener('wheel',     preventScroll, { passive:false, capture:true });
    window.removeEventListener('touchmove', preventScroll, { passive:false, capture:true });
    window.removeEventListener('keydown',   preventKeys,   true);
    window.scrollTo(0, 0);
    if (lenis) { lenis.start(); lenis.resize(); }
    safeScrollTriggerRefresh(true);
  }

  function completeTransition() {
    if (hasCompleted) return;
    hasCompleted = true;
    clearVideoFallback();
    revealHeroScene();
    startSequentialSectionInit();
    if (navbar)      { navbar.style.opacity = '1'; navbar.style.visibility = 'visible'; }
    if (heroIconBtn) { heroIconBtn.style.opacity = '1'; heroIconBtn.style.visibility = 'visible'; }
    if (typeof gsap !== 'undefined') {
      preloaderWrapper.style.pointerEvents = 'none';
      gsap.to(preloaderWrapper, {
        opacity: 0,
        duration: 0.9,
        ease: 'power2.inOut',
        onComplete: () => { preloaderWrapper.style.display = 'none'; }
      });
      setTimeout(enableScrolling, 450);
    } else {
      preloaderWrapper.style.display = 'none';
      setTimeout(enableScrolling, 300);
    }
  }

  // Release video pause guard, play video, wait for it to end then call completeTransition
  function startVideoAndWait() {
    if (hasCompleted) return;
    if (!preloaderVideo) { completeTransition(); return; }
    if (hasStartedVideo) return;
    hasStartedVideo = true;
    if (preloaderVideo.__aurPaused !== undefined) preloaderVideo.__aurPaused = false;
    preloaderVideo.removeAttribute('loop');
    preloaderVideo.currentTime = 0;
    const onEnded = () => {
      preloaderVideo.removeEventListener('ended', onEnded);
      preloaderVideo.removeEventListener('loadedmetadata', scheduleVideoFallback);
      preloaderVideo.removeEventListener('durationchange', scheduleVideoFallback);
      preloaderVideo.removeEventListener('error', onError);
      clearVideoFallback();
      videoFinished = true;
      completeTransition();
    };
    const onError = () => {
      preloaderVideo.removeEventListener('ended', onEnded);
      preloaderVideo.removeEventListener('loadedmetadata', scheduleVideoFallback);
      preloaderVideo.removeEventListener('durationchange', scheduleVideoFallback);
      preloaderVideo.removeEventListener('error', onError);
      clearVideoFallback();
      completeTransition();
    };
    preloaderVideo.addEventListener('ended', onEnded);
    preloaderVideo.addEventListener('loadedmetadata', scheduleVideoFallback);
    preloaderVideo.addEventListener('durationchange', scheduleVideoFallback);
    preloaderVideo.addEventListener('error', onError, { once: true });
    preloaderVideo.muted = true;
    preloaderVideo.volume = 0;
    scheduleVideoFallback();
    preloaderVideo.play().catch(() => {
      clearVideoFallback();
      completeTransition();
    });
  }

  function runPreloader() {
    const progressEl    = document.getElementById('pl-ring-fill');
    const progressTrack = document.getElementById('pl-ring');
    const CIRCUMFERENCE = 1382;

    if (typeof gsap === 'undefined') { startVideoAndWait(); return; }

    if (progressEl) gsap.set(progressEl, { strokeDashoffset: CIRCUMFERENCE });

    let lastProgress = 0;
    function setBarProgress(p) {
      if (!progressEl || p <= lastProgress) return;
      lastProgress = p;
      gsap.to(progressEl, { strokeDashoffset: CIRCUMFERENCE * (1 - Math.min(1, p)), duration: 0.5, ease: 'power1.out', overwrite: 'auto' });
    }
    window.addEventListener('aurix:scene-progress', (e) => setBarProgress(e.detail?.progress ?? 0));

    function triggerOverlayExit() {
      if (overlayDone) return;
      overlayDone = true;
      const brandEls = [
        document.getElementById('pl-logo'),
        document.getElementById('pl-loader'),
        document.getElementById('pl-brand-shadow'),
        progressTrack
      ].filter(Boolean);
      // CSS animation fill-mode overrides GSAP inline opacity — cancel it first so GSAP can tween cleanly
      brandEls.forEach(el => {
        const op = window.getComputedStyle(el).opacity;
        el.style.animation = 'none';
        el.style.opacity = op;
      });
      if (brandEls.length) {
        gsap.to(brandEls, { opacity: 0, duration: 0.55, ease: 'power2.inOut', onComplete: startVideoAndWait });
      } else {
        startVideoAndWait();
      }
    }

    function attemptExit() {
      if (!sceneIsReady || !timelineIsReady) return;
      setBarProgress(1);
      setTimeout(triggerOverlayExit, CFG.holdSeconds * 1000 + 300);
    }

    startVideoStage = () => {
      sceneIsReady = true;
      timelineIsReady = true;
      if (overlayDone) {
        startVideoAndWait();
      } else {
        triggerOverlayExit();
      }
    };

    setTimeout(() => { timelineIsReady = true; attemptExit(); }, MIN_DISPLAY_MS);

    window.addEventListener('aurix:scene-ready', () => {
      sceneIsReady = true;
      setBarProgress(1);
      attemptExit();
    }, { once: true });
  }

  lockScrolling();

  const waitForGsap = () => typeof gsap !== 'undefined' ? runPreloader() : requestAnimationFrame(waitForGsap);
  requestAnimationFrame(waitForGsap);

  setTimeout(() => {
    if (hasCompleted || hasStartedVideo) return;
    if (typeof startVideoStage === 'function') {
      startVideoStage();
    } else {
      startVideoAndWait();
    }
  }, 10000);
})();
let hasStartedSequentialInit = false;

  function scheduleSectionInit(initFn, delay) {
    if (typeof requestIdleCallback !== 'undefined') {
      setTimeout(() => requestIdleCallback(initFn, { timeout: 2000 }), delay);
    } else {
      window.setTimeout(initFn, delay);
    }
  }

    
    
  
function startSequentialSectionInit() {
  if (hasStartedSequentialInit) return;
  hasStartedSequentialInit = true;
  scheduleSectionInit(initDivisionSection, 0);
  scheduleSectionInit(initParticleSection, 180);
  scheduleSectionInit(initWorkMeetSection, 420);
  scheduleSectionInit(initCounterSection, 680);
  scheduleSectionInit(initContactSection, 940);
  scheduleSectionInit(initTinyflowSlider, 1200);
  
  Promise.all([
    document.fonts ? document.fonts.ready : Promise.resolve(),
    new Promise(resolve => {
      if (document.readyState === 'complete') resolve();
      else window.addEventListener('load', resolve);
    })
  ]).then(() => {
    setTimeout(() => {
      safeScrollTriggerRefresh();
    }, 300);
  });
}
function initDivisionSection() {
const divisionSection = document.querySelector('.abt-card-wrapper.is-home');
if (divisionSection) {
  const headingBox = divisionSection.querySelector('.abt-card-heading-box');
  const cardItems = gsap.utils.toArray('.abt-card-item-box');
  if (headingBox) {
    const headingElements = headingBox.querySelectorAll('.division-sub, .division-title, .divi-des, .icon-btn-wrapper');
    gsap.set(headingElements, { opacity: 0, y: 50 });
  }
  gsap.set(cardItems, { opacity: 0, y: 80, scale: 0.9 });
  const divisionTl = gsap.timeline({
    scrollTrigger: {
      trigger: divisionSection,
      start: 'top 70%',
      end: 'bottom 80%',
      scrub: 1,
      markers: false,
    }
  });
  if (headingBox) {
    const headingElements = headingBox.querySelectorAll('.division-sub, .division-title, .divi-des');
    divisionTl.to(headingElements, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power2.out'
    }, 0);
    const buttons = headingBox.querySelectorAll('.icon-btn-wrapper');
    divisionTl.to(buttons, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      stagger: 0.1,
      ease: 'power2.out'
    }, 0.4);
  }
  divisionTl.to(cardItems, {
    opacity: 1,
    y: 0,
    scale: 1,
    duration: 1.2,
    stagger: 0.2,
    ease: 'power2.out'
  }, 0.6);
}
}

function initParticleSection() {
  const section = document.querySelector('.particle-section');
  const title = document.querySelector('.text-box-title');
  const slider = document.querySelector('.spline-slider-wrapper');
  const button = document.querySelector('.partilce-btn-box');
  const navbarLogo = document.querySelector('.navbar31_logo-link');
  const scrollIndicator = section?.querySelector('.scroll-indicator');
  const starBgBox = document.querySelector('.star-bg-box');
  if (!section || !title || !slider) return;

  const totalSlides = 4;
  let currentSlideIndex = 0;
  let fallingStarsInstance = null;
  let particleSectionActive = false;
  const particleIsMobile = window.innerWidth < 768;
  const particleIsTablet = window.innerWidth >= 768 && window.innerWidth < 1024;
  const reduceParticleMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const particleStarConfig = {
    count: reduceParticleMotion ? 0 : (particleIsMobile ? 90 : particleIsTablet ? 135 : 180),
    shadowBlur: reduceParticleMotion ? 0 : (particleIsMobile ? 0 : particleIsTablet ? 8 : 12)
  };
  const particleSlides = Array.from(section.querySelectorAll('.spline-slider-wrapper .slide-item'));

  function initializeStarBackground() {
    const canvas = document.getElementById('starsCanvas');
    const container = document.getElementById('starsContainer');
    if (!canvas || !container) return;
    class FallingStars {
      constructor(canvas, options = {}) {
        this.canvas = canvas;
        this.ctx = canvas.getContext('2d');
        this.color = options.color || '#FFF';
        this.count = options.count || 72;
        this.shadowBlur = options.shadowBlur ?? 12;
        this.stars = [];
        this.perspective = 0;
        this.animationFrame = null;
        this.isAnimating = false;
        this.init();
      }
      init() {
        this.resizeCanvas();
        
        let resizeTimeout;
        window.addEventListener('resize', () => {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(() => {
            this.resizeCanvas();
          }, 250); // Waits for scrolling/resizing to stop before recalculating
        });
        
        if (this.canvas.width > 0 && this.canvas.height > 0) this.initStars();
      }
      initStars() {
        this.perspective = this.canvas.width / 2;
        this.stars = [];
        for (let i = 0; i < this.count; i++) {
          this.stars.push({
            x: (Math.random() - 0.5) * 2 * this.canvas.width,
            y: (Math.random() - 0.5) * 2 * this.canvas.height,
            z: Math.random() * this.canvas.width,
            speed: Math.random() * 5 + 2
          });
        }
      }
      resizeCanvas() {
        const container = this.canvas.parentElement;
        const width = container.clientWidth;
        const height = container.clientHeight;
        if (width > 0 && height > 0) {
          this.canvas.width = width;
          this.canvas.height = height;
          this.canvas.style.width = width + 'px';
          this.canvas.style.height = height + 'px';
          this.perspective = this.canvas.width / 2;
          if (this.stars.length === 0) this.initStars();
        }
      }
      hexToRgb(hex) {
        hex = hex.replace(/^#/, '');
        if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
        const bigint = parseInt(hex, 16);
        return { r: (bigint >> 16) & 255, g: (bigint >> 8) & 255, b: bigint & 255 };
      }
      drawStar(star) {
        const scale = this.perspective / (this.perspective + star.z);
        const x2d = this.canvas.width / 2 + star.x * scale;
        const y2d = this.canvas.height / 2 + star.y * scale;
        const size = Math.max(scale * 3, 0.5);
        const prevScale = this.perspective / (this.perspective + star.z + star.speed * 15);
        const xPrev = this.canvas.width / 2 + star.x * prevScale;
        const yPrev = this.canvas.height / 2 + star.y * prevScale;
        const rgb = this.hexToRgb(this.color);
        if (this.shadowBlur > 0) {
          this.ctx.save();
          this.ctx.strokeStyle = `rgba(${rgb.r},${rgb.g},${rgb.b},0.18)`;
          this.ctx.lineWidth = size * 1.9;
          this.ctx.shadowBlur = this.shadowBlur;
          this.ctx.shadowColor = `rgba(${rgb.r},${rgb.g},${rgb.b},0.65)`;
          this.ctx.beginPath();
          this.ctx.moveTo(x2d, y2d);
          this.ctx.lineTo(xPrev, yPrev);
          this.ctx.stroke();
          this.ctx.restore();
        }
        this.ctx.strokeStyle = `rgba(${rgb.r},${rgb.g},${rgb.b},0.6)`;
        this.ctx.lineWidth = size;
        this.ctx.beginPath();
        this.ctx.moveTo(x2d, y2d);
        this.ctx.lineTo(xPrev, yPrev);
        this.ctx.stroke();
        this.ctx.fillStyle = `rgba(${rgb.r},${rgb.g},${rgb.b},1)`;
        this.ctx.beginPath();
        this.ctx.arc(x2d, y2d, size / 4, 0, Math.PI * 2);
        this.ctx.fill();
      }
      animate() {
        if (!this.isAnimating) return;
        if (this.canvas.width === 0 || this.canvas.height === 0) return;
        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
        this.stars.forEach(star => {
          this.drawStar(star);
          star.z -= star.speed;
          if (star.z <= 0) {
            star.z = this.canvas.width;
            star.x = (Math.random() - 0.5) * 2 * this.canvas.width;
            star.y = (Math.random() - 0.5) * 2 * this.canvas.height;
          }
        });
        this.animationFrame = requestAnimationFrame(() => this.animate());
      }
      start() {
        if (!this.isAnimating) {
          if (this.count === 0) return;
          this.isAnimating = true;
          this.resizeCanvas();
          if (this.stars.length === 0) this.initStars();
          this.animate();
        }
      }
      stop() {
        this.isAnimating = false;
        if (this.animationFrame) {
          cancelAnimationFrame(this.animationFrame);
          this.animationFrame = null;
        }
      }
      setColor(color) { this.color = color; }
    }
    fallingStarsInstance = new FallingStars(canvas, {
      color: '#FFF',
      count: particleStarConfig.count,
      shadowBlur: particleStarConfig.shadowBlur
    });
  }
  initializeStarBackground();

  function prepareParticleVideos() {
    particleSlides.forEach((slide) => {
      slide.querySelectorAll('video').forEach((video) => {
        video.removeAttribute('poster'); // prevent static first-frame showing in letterbox
        video.loop = true;
        video.autoplay = true;
        video.preload = 'none';
        video.muted = true;
        video.defaultMuted = true;
        video.playsInline = true;
        video.setAttribute('playsinline', '');
        video.setAttribute('muted', '');
        video.setAttribute('autoplay', '');
      });
    });
  }

  const particleVideoRetryState = new WeakMap();
  const particleVideoAppliedState = new WeakMap();

  function clearParticleVideoRetry(video) {
    const state = particleVideoRetryState.get(video);
    if (!state) return;
    if (state.timeoutId) {
      window.clearTimeout(state.timeoutId);
    }
    if (state.canPlayHandler) {
      video.removeEventListener('canplay', state.canPlayHandler);
    }
    particleVideoRetryState.delete(video);
  }

  function playActiveParticleVideo(video) {
    if (!video) return;

    clearParticleVideoRetry(video);
    video.autoplay = true;
    video.loop = true;
    video.preload = 'auto';
    video.muted = true;
    video.defaultMuted = true;
    video.playsInline = true;
    video.setAttribute('playsinline', '');
    video.setAttribute('muted', '');
    video.setAttribute('autoplay', '');

    const attemptPlay = () => {
      const playPromise = video.play();
      if (playPromise && typeof playPromise.catch === 'function') {
        playPromise.catch(() => {
          const canPlayHandler = () => {
            clearParticleVideoRetry(video);
            attemptPlay();
          };
          const timeoutId = window.setTimeout(() => {
            clearParticleVideoRetry(video);
            attemptPlay();
          }, 400);
          particleVideoRetryState.set(video, { canPlayHandler, timeoutId });
          video.addEventListener('canplay', canPlayHandler, { once: true });
          if (video.readyState < 2 && typeof video.load === 'function') {
            video.load();
          }
        });
      }
    };

    if (video.readyState >= 2) {
      attemptPlay();
    } else {
      const canPlayHandler = () => {
        clearParticleVideoRetry(video);
        attemptPlay();
      };
      particleVideoRetryState.set(video, { canPlayHandler, timeoutId: null });
      video.addEventListener('canplay', canPlayHandler, { once: true });
      if (typeof video.load === 'function') {
        video.load();
      }
    }
  }

  function applyParticleVideoState(video, shouldPlay) {
    const lastAppliedState = particleVideoAppliedState.get(video);
    const isActuallyPlaying = !video.paused && !video.ended;
    if (lastAppliedState === shouldPlay && (!shouldPlay || isActuallyPlaying)) return;
    particleVideoAppliedState.set(video, shouldPlay);

    if (!shouldPlay) {
      clearParticleVideoRetry(video);
      if (!video.paused) video.pause();
      return;
    }

    if (video.ended) {
      try {
        video.currentTime = 0;
      } catch (error) {}
    }
    playActiveParticleVideo(video);
  }

  function setParticleVideoState() {
    // Use the computed `currentSlideIndex` (updated elsewhere) as the
    // authoritative active slide. This reduces flakiness from relying on
    // computed opacity thresholds during rapid timeline scrubbing.
    particleSlides.forEach((slide, index) => {
      const isVisibleInLayout = slide.style.display !== 'none' && slide.style.visibility !== 'hidden';
      const sliderIsVisible = slider.style.visibility !== 'hidden' && slider.style.display !== 'none';
      const shouldPlay = particleSectionActive && sliderIsVisible && isVisibleInLayout && (index === currentSlideIndex);

      slide.querySelectorAll('video').forEach((video) => {
        video.muted = true;
        video.defaultMuted = true;
