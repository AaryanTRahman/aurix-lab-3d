  function playActiveParticleVideo(video) {
    if (!video) return;
    
    // Reset attributes just in case iOS stripped them
    video.muted = true;
    video.setAttribute('playsinline', '');
    
    if (video.paused) {
      // FIX: Keep it simple. Browsers handle standard play promises best.
      let playPromise = video.play();
      if (playPromise !== undefined) {
        playPromise.catch(error => {
          console.log("Video autoplay prevented:", error);
          // Auto-play was prevented. Wait for user interaction.
        });
      }
    }
  }

  // function setParticleVideoState(activeIndex = 0, shouldPlay = false) {
  //   particleSlides.forEach((slide, index) => {
  //     slide.querySelectorAll('video').forEach((video) => {
  //       if (!shouldPlay || index !== activeIndex) { 
  //         if (!video.paused) video.pause(); 
  //         return; 
