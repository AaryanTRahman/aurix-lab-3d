function startSequentialSectionInit() {
  if (hasStartedSequentialInit) return;
  hasStartedSequentialInit = true;
  // lockHeightsInPixels();
  console.log('startSequentialSectionInit running');
  scheduleSectionInit(initDivisionSection, 0);
  scheduleSectionInit(initParticleSection, 180);
  scheduleSectionInit(initWorkMeetSection, 420);
  scheduleSectionInit(initCounterSection, 680);
  scheduleSectionInit(initContactSection, 940);
  scheduleSectionInit(initTinyflowSlider, 1200);
  
  // FIX 2: Wait for custom fonts and images to ACTUALLY finish loading before refreshing GSAP.
  // This guarantees pin coordinates are calculated on the final, stable layout.
  Promise.all([
    document.fonts ? document.fonts.ready : Promise.resolve(),
    new Promise(resolve => {
      if (document.readyState === 'complete') resolve();
      else window.addEventListener('load', resolve);
    })
  ]).then(() => {
    setTimeout(() => {
      ScrollTrigger.refresh();
      console.log("GSAP Refreshed on stable DOM");
    }, 300);
  });
}
function initDivisionSection() {
const divisionSection = document.querySelector('.abt-card-wrapper.is-home');
if (divisionSection) {
  const headingBox = divisionSection.querySelector('.abt-card-heading-box');
  const cardItems = gsap.utils.toArray('.abt-card-item-box');
  if (headingBox) {
    const headingElements = headingBox.querySelectorAll('.division-sub, .division-title, .divi-des, .icon-btn-wrapper');
    gsap.set(headingElements, { opacity: 0, y: 50 });
  }
  gsap.set(cardItems, { opacity: 0, y: 80, scale: 0.9 });
  const divisionTl = gsap.timeline({
    scrollTrigger: {
      trigger: divisionSection,
      start: 'top 70%',
      end: 'bottom 80%',
      scrub: 1,
      markers: false,
	  // onLeave: () => window.dispatchEvent(new Event('resize')),
      // onEnterBack: () => window.dispatchEvent(new Event('resize'))
    }
  });
  if (headingBox) {
    const headingElements = headingBox.querySelectorAll('.division-sub, .division-title, .divi-des');
    divisionTl.to(headingElements, {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power2.out'
    }, 0);
    const buttons = headingBox.querySelectorAll('.icon-btn-wrapper');
    divisionTl.to(buttons, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      stagger: 0.1,
      ease: 'power2.out'
    }, 0.4);
  }
  divisionTl.to(cardItems, {
    opacity: 1,
    y: 0,
    scale: 1,
    duration: 1.2,
    stagger: 0.2,
    ease: 'power2.out'
  }, 0.6);
}
}

function initParticleSection() {
  console.log('initParticleSection running');
  const section = document.querySelector('.particle-section');
