        const sectionRect = section.getBoundingClientRect();
        
        // Calculate relative to the section's left edge, ignoring global scroll
        const wordCenterX = (wordRect.left - sectionRect.left) + (wordRect.width / 2);
        const sectionCenterX = sectionRect.width / 2;
        return sectionCenterX - wordCenterX;
      },
      y: () => {
        const wordRect = lastWord.getBoundingClientRect();
        const sectionRect = section.getBoundingClientRect();
        
        // Calculate relative to the section's top edge, ignoring global scroll
        const wordCenterY = (wordRect.top - sectionRect.top) + (wordRect.height / 2);
        const sectionCenterY = sectionRect.height / 2;
        return sectionCenterY - wordCenterY;
      },
      scale: initialScale, duration: 0.12, ease: 'power2.inOut'
    }, 0)
