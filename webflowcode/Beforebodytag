      // update progress bar and video as soon as slide is visible
      .add(() => {
        currentSlideIndex = slideIndex;
        updateProgressBar(slideIndex);
        syncParticleVideoPlayback(slideIndex);
      }, inPos + 0.01)

    // ── OUT (only for slides 1–3, slide 4 stays visible until section ends) ──
