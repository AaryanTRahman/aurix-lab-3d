<!-- GSAP, ScrollTrigger, Swiper, and Lenis -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
<script>
(function(){
  document.addEventListener('DOMContentLoaded',function(){
    const slides = Array.from(document.querySelectorAll('.spline-slider-wrapper .slide-item'));
    if(!slides.length) return;
    const vids = slides.map(s=>Array.from(s.querySelectorAll('video')));
    vids.forEach(arr=>arr.forEach(v=>{try{v.muted=true;v.defaultMuted=true;v.playsInline=true;v.loop=true;v.preload='auto';v.setAttribute('playsinline','');v.setAttribute('muted','');}catch(e){}}));
    let active=-1;
    function getActive(){let best=-1,bi=0;slides.forEach((s,i)=>{const o=parseFloat(getComputedStyle(s).opacity||0);if(o>best){best=o;bi=i}});return bi}
    function tryPlay(v){if(!v) return;try{v.muted=true;const p=v.play();if(p&&typeof p.catch==='function')p.catch(()=>{});}catch(e){}}
    function tick(){const idx=getActive();if(idx!==active){active=idx;vids.forEach((arr,i)=>arr.forEach(v=>{if(i===active) tryPlay(v); else try{if(!v.paused) v.pause();}catch(e){}}))}requestAnimationFrame(tick)}
    requestAnimationFrame(tick);
  });
})();
</script>
