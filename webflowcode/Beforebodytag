function initCounterSection() {
  const counterSection = document.querySelector('.counter-section');
  if (counterSection) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const countBtn = counterSection.querySelector('.count-btn');
    const waitlistTitle = counterSection.querySelector('.waitlist-title');
    const numberBoxes = Array.from(counterSection.querySelectorAll('.number-item-box'));
    const prepareReveal = (element) => {
      if (!element) return;
      element.style.opacity = '0';
      element.style.transform = 'translateY(24px)';
      element.style.transition = reduceMotion
        ? 'opacity 0.2s ease'
        : 'opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1), transform 0.45s cubic-bezier(0.22, 1, 0.36, 1)';
      element.style.willChange = 'transform, opacity';
    };
    const showElement = (element, delay = 0) => {
      if (!element) return;
      window.setTimeout(() => {
        element.style.opacity = '1';
        element.style.transform = 'translateY(0)';
      }, delay);
    };
    const animateCounter = (element, targetValue, delay = 0) => {
      if (!element || !Number.isFinite(targetValue)) return;
      const decimals = Number.isInteger(targetValue) ? 0 : 1;
      const duration = reduceMotion ? 0 : 700;
      element.textContent = decimals === 0 ? '0' : '0.0';
      if (duration === 0) {
        window.setTimeout(() => {
          element.textContent = decimals === 0 ? String(targetValue) : targetValue.toFixed(1);
        }, delay);
        return;
      }
      window.setTimeout(() => {
        const startTime = performance.now();
        const step = (now) => {
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const currentValue = targetValue * eased;
          element.textContent = decimals === 0
            ? String(Math.round(currentValue))
            : currentValue.toFixed(1);
          if (progress < 1) {
            requestAnimationFrame(step);
          }
        };
        requestAnimationFrame(step);
      }, delay);
    };
    const counterItems = numberBoxes.map((box) => {
      const numberTitle = box.querySelector('.number-title');
      const numberSec = box.querySelector('.number-sec');
      const numberElement = box.querySelector('.tips, .years, .country');
      const targetValue = parseFloat(numberTitle?.dataset.target || numberElement?.textContent || '0');
      prepareReveal(numberTitle);
      prepareReveal(numberSec);
      return { numberTitle, numberSec, numberElement, targetValue };
    });
    prepareReveal(waitlistTitle);
    prepareReveal(countBtn);
    let counterPlayed = false;
    const playCounterAnimation = () => {
      if (counterPlayed) return;
      counterPlayed = true;
      counterItems.forEach((item, index) => {
        const baseDelay = index * 140;
        showElement(item.numberTitle, baseDelay);
        animateCounter(item.numberElement, item.targetValue, baseDelay + 40);
        showElement(item.numberSec, baseDelay + 100);
      });
      showElement(waitlistTitle, 160);
      showElement(countBtn, 240);
    };
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          playCounterAnimation();
          counterObserver.disconnect();
        }
      });
    }, {
      threshold: 0.25,
      rootMargin: '0px 0px -10% 0px'
    });
    counterObserver.observe(counterSection);
  }
}
