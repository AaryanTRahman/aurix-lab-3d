<script>
(function() {
  const SCENE_URL = 'https://cdn.jsdelivr.net/gh/AaryanTRahman/aurix-lab-3d@main/js/Scene62.js';
  const START_DELAY_MS = 4000;
  let started = false;

  function startScene() {
    if (started) return;
    started = true;
    import(SCENE_URL).catch(function(error) {
      console.error('Aurix scene failed to load', error);
      window.dispatchEvent(new CustomEvent('aurix:scene-error', { detail: { error: error } }));
    });
  }

  function scheduleScene() {
    window.setTimeout(startScene, START_DELAY_MS);
  }

  if (document.readyState === 'complete') {
    scheduleScene();
  } else {
    window.addEventListener('load', scheduleScene, { once: true });
  }
})();
</script>
