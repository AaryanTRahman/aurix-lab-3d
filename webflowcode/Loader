<!-- Brand overlay: logo + dots + progress ring (sits on top of preloader video) -->
<div id="preloader-brand">
  <div class="pl-brand" id="pl-brand-inner">
    <div id="pl-brand-shadow"></div>

    <img src="https://cdn.prod.website-files.com/69dbcca242222c02b829a57b/69f898bae44b7640b88b3afb_White-Gold-icon.png" class="pl-logo" id="pl-logo" alt="Aurix"
         width="260" height="260" fetchpriority="high" decoding="async" />

    <div class="pl-loader" id="pl-loader">
      <div class="pl-dot"></div>
      <div class="pl-dot"></div>
      <div class="pl-dot"></div>
    </div>
  </div>

  <svg class="pl-ring" id="pl-ring" viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle class="pl-ring-track" cx="240" cy="240" r="220"/>
    <circle class="pl-ring-fill" id="pl-ring-fill" cx="240" cy="240" r="220"/>
  </svg>
</div>
