<style>
:root {
  --aurix-loader-bg: #000000;
  --aurix-loader-dim: #2a2518;
  --aurix-loader-mid: #6b5c3a;
  --aurix-loader-low: #9a876a;
  --aurix-loader-main: #cbbb93;
  --aurix-loader-hi: #e3d8bc;
}

.preloader-wrapper {
  background: #000;
}

.preloader-wrapper video,
.preloader-wrapper .w-background-video video {
  opacity: 0.5 !important;
  filter: brightness(0.58) saturate(0.9);
  transform: scale(1.01);
  transition: opacity 0.8s ease, filter 0.8s ease, transform 0.8s ease;
}

.preloader-wrapper.aurix-loader-is-waiting video,
.preloader-wrapper.aurix-loader-is-waiting .w-background-video video {
  opacity: 0.5 !important;
  filter: brightness(0.58) saturate(0.9);
  transform: scale(1.01);
}

.preloader-wrapper.aurix-loader-video-ready video,
.preloader-wrapper.aurix-loader-video-ready .w-background-video video {
  opacity: 1 !important;
  filter: none;
  transform: scale(1);
}

.aurix-loader-embed,
.aurix-loader-embed * {
  box-sizing: border-box;
}

.aurix-loader-embed {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.44);
  font-family: "DM Sans", "Geist", Arial, sans-serif;
  color: var(--aurix-loader-hi);
  transition: background 0.55s ease;
}

.aurix-loader-embed::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--aurix-loader-dim) 1px, transparent 1px),
    linear-gradient(90deg, var(--aurix-loader-dim) 1px, transparent 1px);
  background-size: 48px 48px;
  opacity: 0.35;
  pointer-events: none;
  transition: opacity 0.55s ease;
}

.aurix-loader-embed::after {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(107, 92, 58, 0.5) 0%, transparent 70%);
  animation: aurix-loader-pulse-glow 3s ease-in-out infinite;
  pointer-events: none;
  transition: opacity 0.55s ease;
}

.preloader-wrapper.aurix-loader-video-ready #preloader-brand {
  background: transparent !important;
}

.preloader-wrapper.aurix-loader-video-ready #preloader-brand::before,
.preloader-wrapper.aurix-loader-video-ready #preloader-brand::after {
  opacity: 0 !important;
  animation: none !important;
  background: transparent !important;
}

.preloader-wrapper.aurix-loader-video-ready .aurix-loader-card {
  opacity: 0;
  visibility: hidden;
  transform: scale(0.96);
}

.aurix-loader-card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: min(88vw, 560px);
  gap: clamp(22px, 4vw, 36px);
  padding: clamp(34px, 7vw, 70px) clamp(28px, 8vw, 84px);
  background:
    linear-gradient(135deg, rgba(255, 248, 224, 0.075) 0%, rgba(255, 248, 224, 0.018) 32%, rgba(255, 248, 224, 0) 58%),
    radial-gradient(ellipse at 50% 22%, rgba(203, 187, 147, 0.095), transparent 62%),
    linear-gradient(145deg, rgba(18, 16, 10, 0.24), rgba(0, 0, 0, 0.16));
  border: 1px solid rgba(203, 187, 147, 0.64);
  border-radius: 4px;
  -webkit-backdrop-filter: blur(34px) saturate(1.32) contrast(0.96);
  backdrop-filter: blur(34px) saturate(1.32) contrast(0.96);
  transition: opacity 0.55s ease, visibility 0.55s ease, transform 0.55s ease;
  box-shadow:
    inset 0 1px 0 rgba(255, 248, 224, 0.22),
    inset 0 -1px 0 rgba(203, 187, 147, 0.12),
    inset 0 0 34px rgba(203, 187, 147, 0.04),
    0 0 0 1px rgba(255, 248, 224, 0.035),
    0 24px 90px rgba(0, 0, 0, 0.32),
    0 0 72px rgba(203, 187, 147, 0.075);
}

@supports not ((backdrop-filter: blur(34px)) or (-webkit-backdrop-filter: blur(34px))) {
  .aurix-loader-card {
    background:
      linear-gradient(135deg, rgba(255, 248, 224, 0.07) 0%, rgba(255, 248, 224, 0.02) 42%, rgba(255, 248, 224, 0) 60%),
      radial-gradient(ellipse at 50% 22%, rgba(203, 187, 147, 0.11), transparent 62%),
      linear-gradient(145deg, rgba(18, 16, 10, 0.52), rgba(0, 0, 0, 0.46));
  }
}

.aurix-loader-card-inner {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.aurix-loader-card-inner::before,
.aurix-loader-card-inner::after {
  content: "";
  position: absolute;
  width: 14px;
  height: 14px;
  border-color: rgba(203, 187, 147, 0.72);
  border-style: solid;
}

.aurix-loader-card-inner::before {
  top: 10px;
  right: 10px;
  border-width: 1px 1px 0 0;
}

.aurix-loader-card-inner::after {
  bottom: 10px;
  left: 10px;
  border-width: 0 0 1px 1px;
}

.aurix-loader-shadow {
  position: absolute;
  inset: 12% 8%;
  z-index: -1;
  background: radial-gradient(ellipse at center, rgba(203, 187, 147, 0.08) 0%, transparent 68%);
  filter: blur(34px);
  pointer-events: none;
}

.aurix-loader-logo-wrap {
  width: min(72vw, 340px);
  color: var(--aurix-loader-hi);
  filter: drop-shadow(0 0 18px rgba(203, 187, 147, 0.28));
}

.aurix-loader-logo {
  display: block;
  width: 100%;
  height: auto;
}

.aurix-loader-hex {
  position: relative;
  width: clamp(96px, 18vw, 128px);
  height: clamp(96px, 18vw, 128px);
}

.aurix-loader-hex svg {
  width: 100%;
  height: 100%;
  animation: aurix-loader-spin 2.4s linear infinite;
}

.aurix-loader-center-dot {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.aurix-loader-center-dot::before {
  content: "";
  width: 13px;
  height: 13px;
  border-radius: 50%;
  background: var(--aurix-loader-main);
  box-shadow: 0 0 12px var(--aurix-loader-main), 0 0 24px var(--aurix-loader-mid);
  animation: aurix-loader-dot-pulse 1.2s ease-in-out infinite;
}

.aurix-loader-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(20px, 3vw, 28px);
}

.aurix-loader-dots {
  display: flex;
  gap: 10px;
  align-items: center;
}

.aurix-loader-dots span {
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--aurix-loader-main);
  animation: aurix-loader-dot-wave 1.4s ease-in-out infinite;
}

.aurix-loader-dots span:nth-child(1) { animation-delay: 0s; background: var(--aurix-loader-hi); }
.aurix-loader-dots span:nth-child(2) { animation-delay: 0.15s; background: var(--aurix-loader-main); }
.aurix-loader-dots span:nth-child(3) { animation-delay: 0.30s; background: var(--aurix-loader-low); }
.aurix-loader-dots span:nth-child(4) { animation-delay: 0.45s; background: var(--aurix-loader-main); }
.aurix-loader-dots span:nth-child(5) { animation-delay: 0.60s; background: var(--aurix-loader-hi); }

.aurix-loader-bar {
  width: min(70vw, 280px);
  height: 2px;
  background: rgba(203, 187, 147, 0.12);
  border-radius: 999px;
  overflow: hidden;
}

.aurix-loader-bar-fill {
  height: 100%;
  width: 40%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--aurix-loader-mid), var(--aurix-loader-main));
  box-shadow: 0 0 8px var(--aurix-loader-main);
  animation: aurix-loader-scan 2s ease-in-out infinite;
}

.aurix-loader-label {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  text-align: center;
}

.aurix-loader-label span {
  font-size: 13px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--aurix-loader-main);
  opacity: 0.85;
  animation: aurix-loader-blink-text 3s ease-in-out infinite;
}

.aurix-loader-label small {
  font-size: 11px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--aurix-loader-low);
  opacity: 0.5;
}

html.wf-design-mode #preloader-brand {
  display: none !important;
}

@keyframes aurix-loader-pulse-glow {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}

@keyframes aurix-loader-spin {
  to { transform: rotate(360deg); }
}

@keyframes aurix-loader-dot-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.6); opacity: 0.6; }
}

@keyframes aurix-loader-dot-wave {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.35; }
  40% { transform: translateY(-8px); opacity: 1; }
}

@keyframes aurix-loader-scan {
  0% { transform: translateX(-160%); }
  100% { transform: translateX(370%); }
}

@keyframes aurix-loader-blink-text {
  0%, 100% { opacity: 0.85; }
  50% { opacity: 0.45; }
}

@media (max-width: 480px) {
  .aurix-loader-card {
    width: min(90vw, 360px);
    gap: 24px;
  }

  .aurix-loader-logo-wrap {
    width: min(68vw, 250px);
  }
}
</style>

<script>
(function () {
  function initAurixLoaderVideoFade() {
    var wrapper = document.querySelector(".preloader-wrapper");
    if (!wrapper) return;

    var video = wrapper.querySelector("video");
    wrapper.classList.add("aurix-loader-is-waiting");

    function restoreVideo() {
      wrapper.classList.remove("aurix-loader-is-waiting");
      wrapper.classList.add("aurix-loader-video-ready");
    }

    if (video) {
      video.addEventListener("play", function () {
        if (video.__aurPaused) return;
        restoreVideo();
      }, true);
    }

    window.addEventListener("aurix:scene-ready", function () {
      window.setTimeout(restoreVideo, 1050);
    }, { once: true });

    window.setTimeout(restoreVideo, 10000);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAurixLoaderVideoFade);
  } else {
    initAurixLoaderVideoFade();
  }
})();
</script>